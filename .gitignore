# Sovereign V15 GitIgnore Protocol

# Build Artifacts
**/build/
**/.dart_tool/
**/.pub-cache/
**/.idea/
**/.vscode/
**/*.iml
**/*.apk
**/*.aab


# Python Environment
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Local Data (The Godown takes care of this)
**/vault/data/
**/sound_vault/
**/registry/data/
*.db
*.log
*.err.txt
*_log.txt
*_err.txt

# Sovereign V15: Secure Data Isolation
**/*.json
!package.json
!composer.json
!deno.json
!tsconfig.json
!pubspec.yaml
!pubspec_overrides.yaml
!pubspec.lock
!env_template.json
!docker-compose.yml
!manifest.json
!AssetManifest.json
!FontManifest.json
!NOTICES.json
!canvaskit.js
!skwasm.js

# Environment Secrets & Large Files
**/.env
**/*.env.*
**/*.zip
**/*.tar.gz
**/*.key
**/*.pem
**/token.json
**/client_secret.json
deploy_*.py
master_deploy.py
server_deploy.py
backend/deploy_remote.py
ignite_*.py
sovereign_master_sync.py
nuclear_sync.py

# OS Files
.DS_Store
Thumbs.db
